<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NumberPlate.Pages.Text"
             Title="Text">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="Vehicle Plate Recognition"
                FontSize="22"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                Margin="0,0,0,10"/>

            <!-- Image Preview -->
            <Frame BorderColor="Gray" CornerRadius="10" Padding="0" HeightRequest="240">
                <Image x:Name="PreviewImage"
                    Aspect="AspectFit"
                    BackgroundColor="LightGray"/>
            </Frame>

            <!-- Capture / Pick buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button x:Name="CaptureButton"
                     Grid.Column="0"
                     Text=" Take Photo"
                     Clicked="OnCapturePhotoClicked"
                     BackgroundColor="#2196F3"
                     TextColor="White"/>
                <Button x:Name="PickButton"
                     Grid.Column="1"
                     Text=" Gallery"
                     Clicked="OnPickPhotoClicked"
                     BackgroundColor="#4CAF50"
                     TextColor="White"/>
            </Grid>

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                            IsRunning="False"
                            IsVisible="False"
                            Color="#2196F3"
                            HeightRequest="40"/>

            <!-- Result card -->
            <Frame BorderColor="LightGray" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="8">

                    <!-- Status -->
                    <Label x:Name="StatusLabel"
                        FontSize="15"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"/>

                    <!-- Vehicle number — big and prominent -->
                    <Frame x:Name="NumberFrame"
                        IsVisible="True"
                       
                        CornerRadius="8"
                        Padding="12,8">
                        <Label x:Name="VehicleNumberLabel"
                            IsVisible="False"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="IndianRed"
                            CharacterSpacing="4"
                            HorizontalOptions="Center"/>
                    </Frame>

                    <!-- Plate color badge -->
                    <Label x:Name="PlateColorBadge"
                        IsVisible="False"
                        FontSize="15"
                        HorizontalOptions="Center"/>

                    <!-- Confidence -->
                    <Label x:Name="ConfidenceLabel"
                        IsVisible="False"
                        FontSize="13"
                        HorizontalOptions="Center"/>

                    <!-- Capture time -->
                    <Label x:Name="CaptureTimeLabel"
                        IsVisible="False"
                        FontSize="12"
                        TextColor="Gray"
                        HorizontalOptions="Center"/>


                    <!-- Saved file path -->
                    <Label x:Name="SavedPathLabel"
                        IsVisible="False"
                        FontSize="11"
                        TextColor="Gray"
                        HorizontalOptions="Center"
                        LineBreakMode="TailTruncation"/>



                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>